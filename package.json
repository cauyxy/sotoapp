{
  "name": "sotoapp",
  "version": "0.2.1",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=24.16.0 <25",
    "pnpm": "10.24.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.16.0",
      "onFail": "download"
    }
  },
  "scripts": {
    "dev": "pnpm --filter @soto/desktop dev",
    "build": "pnpm --filter @soto/desktop build",
    "check": "pnpm --filter @soto/core typecheck && pnpm --filter @soto/ipc typecheck && pnpm --filter @soto/native-bridge typecheck && pnpm --filter @soto/desktop typecheck",
    "test": "pnpm test:release-scripts && pnpm test:core && pnpm test:ipc && pnpm test:desktop",
    "test:release-scripts": "node --test scripts/*.test.mjs",
    "test:core": "pnpm --filter @soto/core test",
    "test:ipc": "pnpm --filter @soto/ipc test",
    "test:desktop": "pnpm --filter @soto/desktop test",
    "check:renderer-no-zod": "node scripts/check-renderer-no-zod.mjs",
    "check:bundle-budget": "node scripts/check-renderer-bundle-budget.mjs",
    "smoke:package:mac": "node scripts/smoke-package-macos.mjs",
    "smoke:package:win": "node scripts/verify-windows-native-package.mjs",
    "smoke:uia:win": "node scripts/smoke-windows-uia-capture.mjs",
    "build:mac:signed": "node scripts/sign-macos.mjs"
  },
  "devDependencies": {
    "subset-font": "^2.5.0"
  }
}
