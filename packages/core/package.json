{
  "name": "@soto/core",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Pure-TS Soto core logic (chord matching, session FSM, audio stats, omni client, IPC schemas) — zero Electron/native deps.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./foundation/*": "./src/foundation/*.ts",
    "./contract/*": "./src/contract/*.ts",
    "./capabilities/*": "./src/capabilities/*.ts",
    "./domain/*": "./src/domain/*.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "depcruise": "depcruise src --config .dependency-cruiser.cjs"
  },
  "devDependencies": {
    "dependency-cruiser": "^16.10.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "zod": "^3.24.1"
  }
}
