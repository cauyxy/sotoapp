{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Soto",
  "version": "0.1.0",
  "identifier": "org.sotoapp.sotoapp",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:6782",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Soto",
        "width": 900,
        "height": 600,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": false
      },
      {
        "label": "capsule",
        "title": "Soto Voice Bar",
        "url": "capsule.html",
        "width": 160,
        "height": 64,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "focusable": false,
        "visible": false,
        "shadow": false
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ5NzhDRTk4NTQyMkVENzgKUldSNDdTSlVtTTU0MlZISWw5ZWVtcTJCWm5ZenEyWDFreThyNlN6eTZYWXd5bFRyUEkrOEUveFMK",
      "endpoints": ["https://soto-installer.sotoapp.org/latest.json"]
    }
  }
}
