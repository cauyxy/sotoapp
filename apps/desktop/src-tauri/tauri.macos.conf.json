{
  "$schema": "https://schema.tauri.app/config/2",
  "bundle": {
    "macOS": {
      "entitlements": "entitlements.plist"
    }
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Soto",
        "width": 900,
        "height": 600,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      },
      {
        "label": "capsule",
        "title": "Soto Voice Bar",
        "url": "capsule.html",
        "width": 160,
        "height": 64,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "focusable": false,
        "visible": false,
        "shadow": false
      }
    ]
  }
}
